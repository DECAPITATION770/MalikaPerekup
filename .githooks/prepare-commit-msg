#!/bin/sh
# Monorepo: lefthook lives in tenant/. No prepare-commit-msg commands are
# defined, so this is a no-op delegator that stays silent if lefthook isn't
# resolvable (python-only commits shouldn't see node tooling noise).
[ "$LEFTHOOK" = "0" ] && exit 0
BIN="$(git rev-parse --show-toplevel)/tenant/node_modules/.bin/lefthook"
[ -x "$BIN" ] && (cd "$(git rev-parse --show-toplevel)/tenant" && "$BIN" run prepare-commit-msg "$@") || true
exit 0
