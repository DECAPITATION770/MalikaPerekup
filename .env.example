# ─── Environment ──────────────────────────────────────────────
ENVIRONMENT=dev          # dev | prod
DEBUG=true

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://malika:malika@localhost:5432/malika

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Object storage (MinIO locally, R2 / S3 in prod) ──────────
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=malika-perekup
S3_REGION=us-east-1
S3_SECURE=false
# Optional: host used inside browser-facing pre-signed URLs. Set this
# when the API reaches MinIO over a docker network name (e.g.
# ``minio:9000``) but the browser must resolve a public hostname.
# S3_PUBLIC_ENDPOINT=storage.example.com
# S3_PUBLIC_SECURE=true

# ─── JWT for API authentication (24h tokens) ──────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_TTL_HOURS=24

# ─── Telegram ─────────────────────────────────────────────────
BOT_TOKEN=123456:ABC-DEF-your-bot-token-here
BOT_WEBAPP_URL=https://app.example.com

# ─── Dev-only auth bypass (NEVER set true in prod) ────────────
DEV_AUTH_BYPASS=false
DEV_BYPASS_USER_ID=

# ─── Bootstrap platform admins on first run ───────────────────
# Comma-separated Telegram IDs that get created in `platform_admins`
# the first time the app starts. After the row exists, this var has
# no effect — safe to leave it set.
BOOTSTRAP_ADMIN_TG_IDS=

# Login/password admin — created on first start if platform_admins table is empty.
# Change password before deploying to production!
BOOTSTRAP_ADMIN_LOGIN=admin
BOOTSTRAP_ADMIN_PASSWORD=changeme123
BOOTSTRAP_ADMIN_NAME=Platform Admin

# ─── Locale defaults ──────────────────────────────────────────
DEFAULT_LANGUAGE=ru
TIMEZONE=Asia/Tashkent

# ─── Backups ───────────────────────────────────────────────────
# Directory where backup archives are written (mounted volume in prod).
BACKUP_DIR=/backups
