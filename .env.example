# Malika v2 — environment template
# Copy to .env and fill in real values for local development.

# Runtime
ENV=dev                            # dev | prod
TZ=Asia/Tashkent

# Postgres (matches infra/docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://malika:malika@localhost:5432/malika

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth — JWT signing key. In prod, set via secret manager.
JWT_SECRET=change-me-to-a-long-random-string-in-prod
JWT_TTL_HOURS=24

# Telegram bot — get from @BotFather
BOT_TOKEN=

# Comma-separated Telegram user IDs that become super-admin on login.
# Super-admins provision tenants via /api/admin/tenants UI.
# Find your tg_id via @userinfobot in Telegram.
SUPER_ADMIN_TG_IDS_RAW=

# HTTPS URL where tenant is served (ngrok URL for local Telegram test).
WEBAPP_URL=

# MinIO (S3-compatible) — matches infra/docker-compose.yml
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=malika
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Dev-only: skip Telegram initData verification, log in as user_id=1.
# CRITICAL: must remain false in prod — app/main.py refuses to start otherwise.
DEV_AUTH_BYPASS=false
