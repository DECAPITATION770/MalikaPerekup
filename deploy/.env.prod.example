# ─────────────────────────────────────────────────────────────────────────
# Malika Perekup — PRODUCTION environment (server: 178.128.84.144).
#   cp deploy/.env.prod.example deploy/.env.prod   # then fill the secrets
# NEVER commit deploy/.env.prod (git-ignored).
#
# Non-secret deploy settings (domain, ports, public endpoints) are filled in
# with their REAL values below. Only the secrets are placeholders:
#   - POSTGRES_PASSWORD / DATABASE_URL password   → openssl rand -hex 24
#   - JWT_SECRET                                   → openssl rand -hex 32
#   - S3_ACCESS_KEY / S3_SECRET_KEY                → openssl rand -hex 16/24
#   - BOT_TOKEN                                    → @BotFather
#   - BOOTSTRAP_ADMIN_TG_IDS                       → operator's Telegram id
#   - BOOTSTRAP_ADMIN_PASSWORD                     → strong admin password
#
# The backend refuses to boot in prod if JWT_SECRET is weak, DEV_AUTH_BYPASS
# is on, or DEBUG is on (app/core/config.py:_enforce_prod_guards).
# ─────────────────────────────────────────────────────────────────────────

ENVIRONMENT=prod
DEBUG=false

# ── PostgreSQL ── (internal docker network; not published to the host)
POSTGRES_USER=malika
POSTGRES_PASSWORD=CHANGE_ME_openssl_rand_hex_24
POSTGRES_DB=malika
DATABASE_URL=postgresql+asyncpg://malika:CHANGE_ME_openssl_rand_hex_24@postgres:5432/malika

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── JWT ── (openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_TTL_HOURS=24

# ── Telegram ── (SECRET — fill on the server only)
BOT_TOKEN=CHANGE_ME_botfather_token
BOT_WEBAPP_URL=https://perekup-app.iboshka.xyz

# ── Object storage (self-hosted MinIO) ───────────────────────────────────
# S3_ENDPOINT       — internal: backend → minio over the docker network.
# S3_PUBLIC_ENDPOINT— public host the browser uses for pre-signed URLs;
#                     host nginx proxies it to 127.0.0.1:9120 (minio).
# Cloudflare terminates TLS, so the public side is https while the origin
# hop is http (SigV4 does not sign the scheme, so signatures still match).
S3_ENDPOINT=minio:9000
S3_ACCESS_KEY=CHANGE_ME_minio_access_key
S3_SECRET_KEY=CHANGE_ME_minio_secret_key
S3_BUCKET=malika-perekup
S3_REGION=us-east-1
S3_SECURE=false
S3_PUBLIC_ENDPOINT=perekup-s3.iboshka.xyz
S3_PUBLIC_SECURE=true

# ── Bootstrap first platform admin (seeded only if admins table is empty) ──
BOOTSTRAP_ADMIN_LOGIN=admin
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
BOOTSTRAP_ADMIN_NAME=Platform Admin
# Comma-separated Telegram ids allowed to log into the admin panel.
BOOTSTRAP_ADMIN_TG_IDS=CHANGE_ME_operator_tg_id

# ── Locale ──
DEFAULT_LANGUAGE=ru
TIMEZONE=Asia/Tashkent

# ── Backups ── (written into the backup_data volume at /backups)
BACKUP_DIR=/backups

# ── Dev bypass — MUST stay false in prod (boot guard rejects true) ──
DEV_AUTH_BYPASS=false
