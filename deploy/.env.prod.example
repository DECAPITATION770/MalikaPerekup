# ─────────────────────────────────────────────────────────────────────────
# Malika — PRODUCTION environment.  Copy to deploy/.env.prod and fill in.
#   cp deploy/.env.prod.example deploy/.env.prod
# NEVER commit deploy/.env.prod (it's git-ignored).
#
# The backend refuses to boot in prod if JWT_SECRET is weak, DEV_AUTH_BYPASS
# is on, or DEBUG is on (app/core/config.py:_enforce_prod_guards).
# ─────────────────────────────────────────────────────────────────────────

ENVIRONMENT=prod
DEBUG=false

# ── PostgreSQL ──
# POSTGRES_PASSWORD is consumed by the postgres container AND must match the
# password embedded in DATABASE_URL below.
POSTGRES_USER=malika
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=malika
DATABASE_URL=postgresql+asyncpg://malika:CHANGE_ME_strong_db_password@postgres:5432/malika

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── JWT ── (>= 32 chars, random. Generate: `openssl rand -hex 32`)
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32
JWT_TTL_HOURS=24

# ── Telegram ──
# BOT_TOKEN from @BotFather. BOT_WEBAPP_URL = the public Mini App URL you set
# in BotFather (Bot Settings → Menu Button / Web App). MUST be https.
BOT_TOKEN=CHANGE_ME_botfather_token
BOT_WEBAPP_URL=https://app.example.uz

# ── Object storage ──────────────────────────────────────────────────────
# RECOMMENDED: Cloudflare R2 (managed, private ACL, no MinIO container).
#   S3_ENDPOINT        = <account>.r2.cloudflarestorage.com   (API endpoint)
#   S3_PUBLIC_ENDPOINT = the SAME host (or a custom domain bound to the bucket)
#   S3_SECURE / S3_PUBLIC_SECURE = true  (R2 is https)
# The browser PUTs/GETs presigned URLs against S3_PUBLIC_ENDPOINT, so it must
# be reachable from the client. Keep the bucket PRIVATE — access is only ever
# via short-lived presigned URLs (CLAUDE.md §10).
S3_ENDPOINT=<account>.r2.cloudflarestorage.com
S3_PUBLIC_ENDPOINT=<account>.r2.cloudflarestorage.com
S3_ACCESS_KEY=CHANGE_ME_r2_access_key
S3_SECRET_KEY=CHANGE_ME_r2_secret_key
S3_BUCKET=malika-perekup
S3_REGION=auto
S3_SECURE=true
S3_PUBLIC_SECURE=true
#
# ALTERNATIVE: self-hosted MinIO (start stack with --profile selfhost-storage)
#   S3_ENDPOINT=minio:9000          (internal — backend → minio)
#   S3_PUBLIC_ENDPOINT=cdn.example.uz   (public — browser → minio via nginx)
#   S3_SECURE=false  S3_PUBLIC_SECURE=true   (TLS terminated at the edge)

# ── Bootstrap first platform admin (seeded only if admins table is empty) ──
# Set once for the first boot, then you can blank them out.
BOOTSTRAP_ADMIN_LOGIN=admin
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
BOOTSTRAP_ADMIN_NAME=Platform Admin
# Optional: comma-separated Telegram IDs that may log into the admin panel.
BOOTSTRAP_ADMIN_TG_IDS=

# ── Locale ──
DEFAULT_LANGUAGE=ru
TIMEZONE=Asia/Tashkent

# ── Backups ── (archives written here; mounted from the backup_data volume)
BACKUP_DIR=/backups

# ── Dev bypass — MUST stay false in prod (the boot guard rejects true) ──
DEV_AUTH_BYPASS=false

# ── Optional: Sentry error tracking ──
# SENTRY_DSN=
